# Gemini API settings
GEMINI_API_KEY=your_gemini_api_key_here

# Google Credentials settings
# Path to service account credential JSON file (relative or absolute)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json

# Google Sheet URLs for all 7 teams
# Format: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_PDM_URL=
GOOGLE_SHEET_KAI_URL=
GOOGLE_SHEET_SU_URL=
GOOGLE_SHEET_Q_URL=
GOOGLE_SHEET_FARBOOKMARK_URL=
GOOGLE_SHEET_OEITUK_URL=
GOOGLE_SHEET_JIRAPAH_URL=

# App Environment (development / production)
ENV=development
